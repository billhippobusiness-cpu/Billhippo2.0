# ===========================================
# BillHippo Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git!
#
# HOW TO GET THESE VALUES:
# 1. Go to https://console.firebase.google.com
# 2. Select your project → Project Settings (gear icon)
# 3. Scroll to "Your apps" section → Web app config
# 4. Copy each value below
# ===========================================

# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key-here
# Auth domain for Google sign-in. Leave blank to use the default Firebase domain
# (<projectId>.firebaseapp.com), which works out of the box with Google sign-in.
# Only set this if you have a custom authDomain configured in Google Cloud Console.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-your-measurement-id

# ===========================================
# App Check (reCAPTCHA v3)
# ===========================================
# Protects your Cloud Functions / Firestore / Storage from bot & script abuse.
# HOW TO GET THIS VALUE:
# 1. Firebase Console → App Check → Apps → register your Web app
# 2. Choose "reCAPTCHA v3" as the provider
# 3. Copy the reCAPTCHA v3 SITE key (the public key, NOT the secret key)
# Leave blank to disable App Check (e.g. for early local development).
VITE_RECAPTCHA_SITE_KEY=

# ===========================================
# Tally Integration (Accounts page)
# ===========================================
# Feature flag for the Tally accounting integration. The "Accounts" sidebar
# item is hidden unless this is set to "true". Keep it off in production until
# the BillHippo Desktop Connector ships.
VITE_TALLY_ENABLED=false

# Public download URL for the signed Windows connector installer. When set, the
# "Download for Windows" button on the Accounts page becomes active.
VITE_CONNECTOR_DOWNLOAD_URL=
