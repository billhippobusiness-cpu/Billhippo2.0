# ===========================================
# BillHippo Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git!
#
# HOW TO GET THESE VALUES:
# 1. Go to https://console.firebase.google.com
# 2. Select your project → Project Settings (gear icon)
# 3. Scroll to "Your apps" section → Web app config
# 4. Copy each value below
# ===========================================

# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key-here
# Auth domain for Google sign-in. Leave blank to use the default Firebase domain
# (<projectId>.firebaseapp.com), which works out of the box with Google sign-in.
# Only set this if you have a custom authDomain configured in Google Cloud Console.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-your-measurement-id

# ===========================================
# WhatsApp Business API (Cloud Functions only — NOT client-side)
# These are set server-side via Firebase CLI, never in this .env file.
# ===========================================
#
# 1. Permanent access token (stored in Firebase Secret Manager):
#    firebase functions:secrets:set WHATSAPP_ACCESS_TOKEN
#    (Obtain from Meta Business Suite → System Users → Generate token
#     with scopes: whatsapp_business_messaging, whatsapp_business_management)
#
# 2. Phone Number ID (plain param, not secret):
#    firebase functions:params:set WHATSAPP_PHONE_NUMBER_ID=1071356189388444
#    (Found in WhatsApp Manager → Phone numbers → settings icon)
#
# 3. Message template: Create "billhippo_otp" in WhatsApp Manager → Manage templates
#    Category: Utility | Body: "Your BillHippo verification code is *{{1}}*. This code expires in 10 minutes. Do not share it with anyone."
